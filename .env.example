# TokenPulse 环境变量示例
# 请将此文件复制为 .env 并填写您的配置值

# 服务器配置
PORT=9009
NODE_ENV=production
# 安全警告：生产环境中必须修改此密钥！
API_SECRET=your-secure-api-secret-here
BASE_URL=http://localhost:9009
ENABLE_ADVANCED=false
EXPOSE_METRICS=false
# CORS_ALLOW_ORIGINS=http://localhost:8085,https://your-domain.example.com

# 数据库配置
DB_FILE_NAME=data/credentials.db

# 网络配置（可选）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# OAuth 配置（可选覆盖）
# 客户端 ID 通常可公开；客户端密钥必须通过环境变量注入，严禁写入代码。

# ANTIGRAVITY_CLIENT_ID=
# ANTIGRAVITY_CLIENT_SECRET=

# GEMINI_CLIENT_ID=
# GEMINI_CLIENT_SECRET=

# CLAUDE_CLIENT_ID=
# CODEX_CLIENT_ID=
# QWEN_CLIENT_ID=
# COPILOT_CLIENT_ID=

# IFLOW_CLIENT_ID=
# IFLOW_CLIENT_SECRET=
