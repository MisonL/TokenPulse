# TokenPulse 环境变量示例
# 请将此文件复制为 .env 并填写您的配置值

# 服务器配置
PORT=9009
NODE_ENV=production
# 安全警告：生产环境中必须修改此密钥！
API_SECRET=your-secure-api-secret-here
BASE_URL=http://localhost:9009
ENABLE_ADVANCED=false
EXPOSE_METRICS=false
TRUST_PROXY=false
# CORS_ALLOW_ORIGINS=http://localhost:8085,https://your-domain.example.com

# 企业版管理员认证（local | header | hybrid）
ADMIN_AUTH_MODE=hybrid
# 仅在 TRUST_PROXY=true 且该值=true 时启用 x-admin-* 透传身份
ADMIN_TRUST_HEADER_AUTH=false
ADMIN_SESSION_COOKIE_NAME=tp_admin_session
ADMIN_SESSION_TTL_HOURS=24
# 首次启动自动创建管理员（仅在 admin_users 为空时生效）
ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_PASSWORD=请设置强密码

# Claude 逆向传输策略（strict | bridge）
CLAUDE_TLS_MODE=strict
CLAUDE_BRIDGE_URL=http://127.0.0.1:9460

# OAuth 多账号路由策略
OAUTH_SELECTION_POLICY=round_robin
OAUTH_SELECTION_ALLOW_HEADER_OVERRIDE=true
ALLOW_HEADER_ACCOUNT_OVERRIDE=false
OAUTH_SELECTION_FAILURE_COOLDOWN_SEC=120
OAUTH_SELECTION_MAX_RETRY_ON_ACCOUNT_FAILURE=1

# 数据库配置
DB_FILE_NAME=data/credentials.db

# 网络配置（可选）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# OAuth 配置（可选覆盖）
# 客户端 ID 通常可公开；客户端密钥必须通过环境变量注入，严禁写入代码。

# ANTIGRAVITY_CLIENT_ID=
# ANTIGRAVITY_CLIENT_SECRET=

# GEMINI_CLIENT_ID=
# GEMINI_CLIENT_SECRET=

# CLAUDE_CLIENT_ID=
# CODEX_CLIENT_ID=
# QWEN_CLIENT_ID=
# COPILOT_CLIENT_ID=

# IFLOW_CLIENT_ID=
# IFLOW_CLIENT_SECRET=
