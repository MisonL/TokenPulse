# TokenPulse 环境变量示例
# 请将此文件复制为 .env 并填写您的配置值

# 服务器配置
PORT=9009
NODE_ENV=production
# 安全警告：生产环境中必须修改此密钥！
API_SECRET=your-secure-api-secret-here
BASE_URL=http://localhost:9009
ENABLE_ADVANCED=false
EXPOSE_METRICS=false
TRUST_PROXY=false
# 开启后才会信任反向代理透传的 x-admin-* 与 x-tokenpulse-* 身份头
# CORS_ALLOW_ORIGINS=http://localhost:8085,https://your-domain.example.com

# 企业版管理员认证（local | header | hybrid）
ADMIN_AUTH_MODE=hybrid
# 仅在 TRUST_PROXY=true 且该值=true 时启用 x-admin-* 透传身份
ADMIN_TRUST_HEADER_AUTH=false
ADMIN_SESSION_COOKIE_NAME=tp_admin_session
ADMIN_SESSION_TTL_HOURS=24
# 首次启动自动创建管理员（仅在 admin_users 为空时生效）
ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_PASSWORD=请设置强密码

# Claude 逆向传输策略（strict | bridge）
CLAUDE_TLS_MODE=strict
CLAUDE_BRIDGE_URL=http://127.0.0.1:9460
CLAUDE_BRIDGE_UPSTREAM=https://api.anthropic.com/v1/messages?beta=true
CLAUDE_BRIDGE_SHARED_KEY=
CLAUDE_BRIDGE_DISABLE_HTTP2=false
CLAUDE_BRIDGE_TIMEOUT_MS=12000
CLAUDE_BRIDGE_MAX_RETRIES=1
CLAUDE_BRIDGE_CIRCUIT_THRESHOLD=5
CLAUDE_BRIDGE_CIRCUIT_COOLDOWN_SEC=60

# 核心网关 -> 企业控制面代理配置（建议在生产启用共享密钥）
ENTERPRISE_BASE_URL=http://127.0.0.1:9010
ENTERPRISE_PROXY_TIMEOUT_MS=5000
ENTERPRISE_SHARED_KEY=

# OAuth 多账号路由策略
OAUTH_SELECTION_POLICY=round_robin
OAUTH_SELECTION_ALLOW_HEADER_OVERRIDE=true
ALLOW_HEADER_ACCOUNT_OVERRIDE=false
OAUTH_SELECTION_FAILURE_COOLDOWN_SEC=120
OAUTH_SELECTION_MAX_RETRY_ON_ACCOUNT_FAILURE=1

# OAuth 告警（5m 窗口评估）
OAUTH_ALERT_EVAL_INTERVAL_SEC=60
OAUTH_ALERT_WEBHOOK_URL=
OAUTH_ALERT_WEBHOOK_SECRET=
OAUTH_ALERT_WECOM_WEBHOOK_URL=
# 逗号分隔；可填写企业微信 userid 或 @all
OAUTH_ALERT_WECOM_MENTIONED_LIST=
# 静默时段/最小投递级别/Provider 抑制请通过管理接口配置：
# /api/admin/observability/oauth-alerts/config

# Alertmanager 控制面（后台下发 + reload/ready）
ALERTMANAGER_CONTROL_ENABLED=false
ALERTMANAGER_RUNTIME_DIR=./monitoring/runtime
ALERTMANAGER_CONFIG_FILENAME=alertmanager.generated.yml
ALERTMANAGER_RELOAD_URL=http://127.0.0.1:9093/-/reload
ALERTMANAGER_READY_URL=http://127.0.0.1:9093/-/ready
ALERTMANAGER_REQUEST_TIMEOUT_MS=5000

# 数据库配置（PostgreSQL）
DATABASE_URL=postgresql://tokenpulse:tokenpulse@127.0.0.1:5432/tokenpulse

# 网络配置（可选）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# OAuth 配置（可选覆盖）
# 客户端 ID 通常可公开；客户端密钥必须通过环境变量注入，严禁写入代码。

# ANTIGRAVITY_CLIENT_ID=
# ANTIGRAVITY_CLIENT_SECRET=

# GEMINI_CLIENT_ID=
# GEMINI_CLIENT_SECRET=

# CLAUDE_CLIENT_ID=
# CODEX_CLIENT_ID=
# QWEN_CLIENT_ID=
# COPILOT_CLIENT_ID=

# IFLOW_CLIENT_ID=
# IFLOW_CLIENT_SECRET=
