{
  "name": "tokenpulse",
  "version": "1.4.2",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend",
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "start": "bun run src/lib/migrate.ts && bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "start:core": "bun run apps/core/src/index.ts",
    "dev:core": "bun --watch apps/core/src/index.ts",
    "start:enterprise": "PORT=9010 bun run apps/enterprise/src/index.ts",
    "dev:enterprise": "PORT=9010 bun --watch apps/enterprise/src/index.ts",
    "start:bridge": "PORT=9460 bun run services/claude-utls-bridge/src/index.ts",
    "dev:bridge": "PORT=9460 bun --watch services/claude-utls-bridge/src/index.ts",
    "start:bridge:go": "go run ./services/claude-utls-bridge-go/cmd/bridge",
    "dev:bridge:go": "go run ./services/claude-utls-bridge-go/cmd/bridge",
    "test": "NODE_ENV=test bun test",
    "test:coverage": "NODE_ENV=test bun test --coverage",
    "db:push": "bun drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "bun drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.2",
    "@hono/zod-validator": "^0.7.6",
    "@types/node": "^25.0.9",
    "drizzle-kit": "latest",
    "drizzle-orm": "latest",
    "hono": "^4.0.0",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.6"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
