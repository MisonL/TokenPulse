# OAuth Alertmanager 生产窗口参数模板（示例）
# 使用方式：
#   cp scripts/release/release_window_oauth_alerts.env.example scripts/release/release_window_oauth_alerts.env
#   编辑 scripts/release/release_window_oauth_alerts.env 并填入真实值

# 必填参数（映射到 release_window_oauth_alerts.sh）
RW_BASE_URL="https://core.example.com"
RW_API_SECRET="__REPLACE_WITH_API_SECRET__"
RW_OWNER_USER="__REPLACE_WITH_OWNER_USER__"
RW_OWNER_ROLE="__REPLACE_WITH_OWNER_ROLE__"
RW_AUDITOR_USER="__REPLACE_WITH_AUDITOR_USER__"
RW_AUDITOR_ROLE="__REPLACE_WITH_AUDITOR_ROLE__"
RW_WARNING_SECRET_REF="__REPLACE_WITH_WARNING_SECRET_REF__"
RW_CRITICAL_SECRET_REF="__REPLACE_WITH_CRITICAL_SECRET_REF__"
RW_P1_SECRET_REF="__REPLACE_WITH_P1_SECRET_REF__"
RW_SECRET_CMD_TEMPLATE="__REPLACE_WITH_SECRET_CMD_TEMPLATE__"

# 可选参数
RW_OWNER_TENANT=""
RW_AUDITOR_TENANT=""
RW_WITH_ROLLBACK="false"
RW_EVIDENCE_FILE="./artifacts/release-window-evidence.json"
RW_RUN_TAG=""
RW_INSECURE="false"

# Alertmanager 挂载路径（供 docker compose monitoring profile 与发布前预检使用）
# 仓库示例/本地演练配置不会通过发布预检；发布前请改为运行时注入的生产文件。
ALERTMANAGER_CONFIG_PATH="./monitoring/runtime/alertmanager.prod.yml"
ALERTMANAGER_TEMPLATES_PATH="./monitoring/alertmanager-templates"

# 示例：
# RW_SECRET_CMD_TEMPLATE='secret-manager read {{secret_ref}}'
# RW_SECRET_CMD_TEMPLATE='secret-manager read %s'
# 本地演练示例（仅 webhook sink，不可用于发布）：
# ALERTMANAGER_CONFIG_PATH='./monitoring/alertmanager.webhook.local.example.yml'
